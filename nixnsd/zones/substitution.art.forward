$TTL 7200
@   IN SOA r.floffel.de. postmaster.minnecker.com. (
    1781361000	; serial
    14400       ; refresh
    3600        ; retry
    604800      ; expire
    86400 )     ; minimum

 
@			 IN NS	    r.floffel.de.
@			 IN NS	    ns2.minnecker.com.
 
@                        IN MX 10   riese.minnecker.com.
@                        IN TXT     "v=spf1 a mx -all"
@                        IN TXT     "v=DMARC1; p=reject; sp=reject; rua=mailto:postmaster@minnecker.com"

substitution.art.		 IN CAA	0   issue "letsencrypt.org"

substitution.art._domainkey IN TXT     ( "v=DKIM1; k=rsa; "
	"p=MIGfMA0GCSqGSIb3DQEBAQUAA4GNADCBiQKBgQC/CJG+JldHRHctxRdKz5RfaCOfqSXEYyvbVDsBoEgdgU2vU7dpQu8iIi0IvLm2ImGMmp1duxQPxp1oec5fltHdNKK39GK2aoVinIr+wcBkJwjNzZUSngeqIlzXRXXe72mNKpFVAxs9qgIHMQyjz9V/VhjcKxE2CwbEkgumGV9aKQIDAQAB" )  ; ----- DKIM key minnecker.com for (your domain)

autoconfig               IN CNAME   mail.minnecker.com.
_autodiscover._tcp       IN SRV     0 100 443 mail.minnecker.com.

@                        IN A       157.180.8.210
@                        IN AAAA    2a01:4f9:3100:312b::2

www			 IN CNAME  px.minnecker.com.
app			 IN CNAME  www

local		0        IN A 127.0.0.1
